# ============================================================
# AutoRoute AI — Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# Port the Express server listens on (default: 3001)
PORT=3001

# URL of the React frontend (for CORS)
FRONTEND_URL=http://localhost:5173

# Anthropic API key — get yours at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase / PostgreSQL connection string (Phase 2)
DATABASE_URL=your_supabase_database_url_here
